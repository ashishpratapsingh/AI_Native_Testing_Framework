# Copy to .env and fill in. Never commit .env.
# Each app under src/apps/<app>/ declares its own vars in its env.ts —
# onboarding a new app means ADDING vars here, never editing another app's.

# app: khatova
UI_BASE_URL=<Fill-here>

# khatova admin creds
ADMIN_EMAIL=<Fill-here>
ADMIN_PASSWORD=<Fill-here>

# Runtime
CI=false